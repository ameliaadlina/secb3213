# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real credentials.

# Your MongoDB Atlas connection string (from Atlas -> Connect -> Compass / Drivers).
# Replace <db_password> with your actual database user's password.
CTMS_MONGO_URI=

# Database name — all scripts/API/portal use this same DB.
CTMS_DB_NAME=ctms

# Only needed by the portal — where it finds the running API.
# Leave as-is for local dev; change if you deploy the API elsewhere.
CTMS_API_BASE_URL=http://127.0.0.1:8000
