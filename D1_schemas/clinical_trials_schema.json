{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Clinical Trials",
    "description": "Central entity. Defines one or more treatment arms. Referenced by interventions.trial_id, patients.enrolled_trials, and adverse_events.trial_id.",
    "required": [
      "trial_id",
      "title",
      "short_title",
      "phase",
      "status",
      "sponsor",
      "conditions",
      "interventions",
      "start_date",
      "estimated_end_date",
      "enrolment_target",
      "enrolled_count",
      "arms",
      "primary_endpoint",
      "secondary_endpoints",
      "sites",
      "ethical_approval",
      "created_at"
    ],
    "properties": {
      "trial_id": {
        "bsonType": "string",
        "pattern": "^NCT-[0-9]{8}$",
        "description": "Unique. Format NCT-XXXXXXXX, e.g. NCT-20240001."
      },
      "title": { "bsonType": "string" },
      "short_title": {
        "bsonType": "string",
        "maxLength": 80
      },
      "phase": {
        "bsonType": "string",
        "enum": ["Phase I", "Phase II", "Phase III", "Phase IV", "Not Applicable"]
      },
      "status": {
        "bsonType": "string",
        "enum": ["Recruiting", "Active (not recruiting)", "Completed", "Terminated", "Suspended", "Withdrawn"]
      },
      "sponsor": { "bsonType": "string" },
      "conditions": {
        "bsonType": "array",
        "minItems": 1,
        "maxItems": 4,
        "items": { "bsonType": "string" }
      },
      "interventions": {
        "bsonType": "array",
        "description": "Array of intervention_id strings (references interventions.intervention_id). One trial may have multiple interventions, one per arm.",
        "items": {
          "bsonType": "string",
          "pattern": "^INT-[0-9]{6}$"
        }
      },
      "start_date": { "bsonType": "date" },
      "estimated_end_date": { "bsonType": "date" },
      "enrolment_target": {
        "bsonType": "int",
        "minimum": 30,
        "maximum": 2000
      },
      "enrolled_count": {
        "bsonType": "int",
        "minimum": 0,
        "description": "Must be <= enrolment_target (enforced at application level; JSON Schema cannot compare two sibling fields)."
      },
      "arms": {
        "bsonType": "array",
        "description": "1-4 arms. Defines the trial's treatment strategies. Each intervention carries a reference back to its arm by arm_label.",
        "minItems": 1,
        "maxItems": 4,
        "items": {
          "bsonType": "object",
          "required": ["arm_label", "arm_type", "description"],
          "properties": {
            "arm_label": { "bsonType": "string" },
            "arm_type": {
              "bsonType": "string",
              "enum": ["Experimental", "Active Comparator", "Placebo Comparator", "No Intervention"]
            },
            "description": { "bsonType": "string" }
          }
        }
      },
      "primary_endpoint": { "bsonType": "string" },
      "secondary_endpoints": {
        "bsonType": "array",
        "minItems": 1,
        "maxItems": 5,
        "items": { "bsonType": "string" }
      },
      "sites": {
        "bsonType": "array",
        "items": {
          "bsonType": "string",
          "enum": ["SITE-01", "SITE-02", "SITE-03", "SITE-04", "SITE-05"]
        }
      },
      "ethical_approval": {
        "bsonType": "object",
        "required": ["approval_id", "committee", "approved_on"],
        "properties": {
          "approval_id": { "bsonType": "string" },
          "committee": { "bsonType": "string" },
          "approved_on": { "bsonType": "date" }
        }
      },
      "created_at": { "bsonType": "date" }
    }
  }
}
